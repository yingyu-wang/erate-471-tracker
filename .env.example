PORT=3000
DATABASE_URL=postgresql://erate:erate_secret@localhost:5432/erate_471

# USAC Open Data import (defaults: California only)
USAC_API_BASE=https://opendata.usac.org
USAC_IMPORT_STATE=CA
# Rows per USAC API request (Socrata max is 50000)
USAC_IMPORT_PAGE_SIZE=50000
USAC_IMPORT_INCLUDE_PENDING=true
# USAC_IMPORT_FUNDING_YEAR_MIN=2024
# USAC_IMPORT_FUNDING_YEAR_MAX=2026

# Docker first-start import (set in docker-compose.yml)
# AUTO_IMPORT_USAC=true
# FORCE_USAC_IMPORT=true

# Incremental sync (subsequent Docker restarts / manual imports)
# USAC_SYNC_MODE=auto
# USAC_SYNC_YEAR_WINDOW=2
# USAC_SYNC_CHECK_DATASETS=true
# USAC_SYNC_MIN_INTERVAL_HOURS=24

# Live search (queries USAC Open Data when user searches applications)
# USAC_LIVE_SEARCH_LIMIT=50
# USAC_LIVE_SEARCH_FRN_LIMIT=5000

# Use the Python sodapy SDK port for the USAC import (bulk + web "Import CA Data" button)
# USE_PYTHON_USAC_IMPORT=true
