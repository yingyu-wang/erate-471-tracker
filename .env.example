# Production Environment Variables Template
# Copy this file to .env and fill in your actual values
# 
# REQUIRED:
DATABASE_URL=postgresql://erate_user:your_secure_password_here@postgres.example.com:5432/erate_471

# OPTIONAL - Database credentials (for local PostgreSQL only)
DB_USER=erate_user
DB_PASSWORD=your_secure_password_here

# OPTIONAL - API Authentication
# Leave empty "" to disable authentication, or set to a secure value to enable X-API-Key header validation
API_KEY=sk-prod-your-32-character-secret-key-here

# OPTIONAL - CORS Origins
# Comma-separated list of allowed origins for cross-origin requests
CORS_ORIGINS=https://erate.example.com,https://www.erate.example.com

# OPTIONAL - Auto-import USAC data on startup
# Set to "true" only on first deployment, then set to "false" for subsequent restarts
AUTO_IMPORT_USAC=false
